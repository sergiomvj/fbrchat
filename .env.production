# Shared
NODE_ENV=production
APP_PORT=3000
BACKEND_PORT=3000
FRONTEND_PORT=80
ORCHESTRATOR_PORT=3001

# Auth
JWT_ACCESS_SECRET=replace-me-access-prod
JWT_REFRESH_SECRET=replace-me-refresh-prod
JWT_ACCESS_TTL=24h
JWT_REFRESH_TTL=30d

# Database (Internal Docker Network Routing)
POSTGRES_USER=fbr_admin
POSTGRES_PASSWORD=fbr_secure_password
POSTGRES_DB=fbr_chat
DATABASE_URL=postgres://fbr_admin:fbr_secure_password@postgres:5432/fbr_chat

# Redis (Internal Docker Network Routing)
REDIS_URL=redis://redis:6379

# Storage (MinIO Internal)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minio_secure_password
MINIO_BUCKET=fbr-chat-media

# OpenClaw
OPENCLAW_ENDPOINT=https://api.openclaw.com/v1/chat
OPENCLAW_VENDAS_KEY=replace-me
OPENCLAW_RH_KEY=replace-me
OPENCLAW_PRODUTO_KEY=replace-me

# Integrations
ARVA_SHARED_TOKEN=replace-me-arva

# Voice
OPENAI_API_KEY=replace-me
ELEVENLABS_API_KEY=replace-me
