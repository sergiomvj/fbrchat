generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id         String   @id @default(uuid())
  name       String
  slug       String   @unique
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  agents     Agent[]

  @@map("companies")
}

model User {
  id             String    @id @default(uuid())
  name           String
  email          String    @unique
  password       String
  role           String    @default("user") // admin, user
  avatar_url     String?
  is_active      Boolean   @default(true)
  created_at     DateTime  @default(now())
  last_seen      DateTime?
  deactivated_at DateTime?

  @@map("users")
}

model Agent {
  id                  String    @id @default(uuid())
  name                String
  slug                String    @unique
  provider            String?
  provider_agent_id   String?
  arva_agent_id       String?
  company_id          String?
  company             Company?  @relation(fields: [company_id], references: [id])
  role                String?
  owner_company_id    String?
  owner_company_name  String?
  avatar_url          String?
  description         String?
  openclaw_config     Json?
  tts_enabled         Boolean   @default(false)
  tts_voice_id        String?
  is_active           Boolean   @default(true)
  sync_source         String?
  last_synced_at      DateTime?
  persona_profile     Json?
  runtime_profile     Json?
  performance_profile Json?
  created_at          DateTime  @default(now())

  @@map("agents")
}

model Group {
  id          String   @id @default(uuid())
  name        String
  description String?
  topic       String?
  created_by  String
  created_at  DateTime @default(now())
  is_active   Boolean  @default(true)

  @@map("groups")
}

model GroupMember {
  group_id    String
  member_type String // user, agent
  member_id   String
  joined_at   DateTime @default(now())

  @@id([group_id, member_type, member_id])
  @@map("group_members")
}

model Pvt {
  id                 String    @id @default(uuid())
  participant_a_type String
  participant_a_id   String
  participant_b_type String
  participant_b_id   String
  last_message_at    DateTime?
  created_at         DateTime  @default(now())

  @@unique([participant_a_type, participant_a_id, participant_b_type, participant_b_id])
  @@map("pvts")
}

model Message {
  id                String   @id @default(uuid())
  conversation_id   String
  conversation_type String // group, pvt
  sender_type       String // user, agent
  sender_id         String?
  content           String?
  media_url         String?
  media_type        String?
  tts_audio_url     String?
  created_at        DateTime @default(now())
  read_by           Json? // Array of user IDs
  status            String   @default("sent")
  transcription     String?

  @@index([conversation_id, conversation_type])
  @@map("messages")
}

model SystemSettings {
  id                   Int     @id @default(1)
  stt_enabled          Boolean @default(true)
  tts_enabled          Boolean @default(true)
  inference_rate_limit Int     @default(500)

  @@map("system_settings")
}

model OpenclawLog {
  id         String   @id @default(uuid())
  agent_id   String?
  status     String?
  payload    Json?
  response   Json?
  created_at DateTime @default(now())

  @@map("openclaw_logs")
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  user_id    String
  expires_at DateTime
  created_at DateTime @default(now())

  @@map("refresh_tokens")
}
