# Shared
NODE_ENV=development
APP_PORT=3000
BACKEND_PORT=3000
FRONTEND_PORT=5173
ORCHESTRATOR_PORT=3001

# Auth
JWT_ACCESS_SECRET=replace-me-access
JWT_REFRESH_SECRET=replace-me-refresh
JWT_ACCESS_TTL=24h
JWT_REFRESH_TTL=30d

# Database
DATABASE_URL=postgresql://postgres:senha@aws-1-us-west-2.pooler.supabase.com:5432/postgres

SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me

# Redis
REDIS_URL=redis://default:senha@@tools_redis-fbrchat:6379

# Storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SERVER_URL=https://tools-minio-fbrchat.ldm9ti.easypanel.host
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=fbr-chat-media

# OpenClaw
OPENCLAW_ENDPOINT=https://example-openclaw.local/v1/chat
OPENCLAW_VENDAS_KEY=replace-me
OPENCLAW_RH_KEY=replace-me
OPENCLAW_PRODUTO_KEY=replace-me

# Integrations
ARVA_SHARED_TOKEN=replace-me-arva

# Voice
OPENAI_API_KEY=replace-me
ELEVENLABS_API_KEY=replace-me
